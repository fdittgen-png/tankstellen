.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Golden-test failure artifacts — diff dumps the test framework writes
# when a golden mismatches locally. Transient build output, never
# source. The committed golden *masters* (test/goldens/*.png) stay
# tracked (#1723).
test/goldens/failures/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Secrets — NEVER commit
*.jks
*.keystore
key.properties
*.env
credentials.json

