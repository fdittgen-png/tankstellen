{
  "approachOverlaySection": "Fuel Station Radar",
  "@approachOverlaySection": {
    "description": "Section title in the profile edit sheet for the in-trip Fuel Station Radar settings (#2067 / Epic #2065 / #2661)."
  },
  "approachRadiusLabel": "Radius",
  "@approachRadiusLabel": {
    "description": "Slider label for the Fuel Station Radar radius (km)."
  },
  "approachRadiusCaption": "Radar leads with the price when within {km} km of a fuel station",
  "@approachRadiusCaption": {
    "description": "Caption under the approach-radius slider.",
    "placeholders": {
      "km": {
        "type": "String",
        "example": "1.0"
      }
    }
  },
  "approachPriceModeLabel": "Show price for",
  "@approachPriceModeLabel": {
    "description": "Title above the nearest/cheapest-in-radius choice chips."
  },
  "approachPriceModeNearest": "Nearest station",
  "@approachPriceModeNearest": {
    "description": "Choice chip — overlay shows the price at the single nearest station the driver crossed the radius of."
  },
  "approachPriceModeCheapestInRadius": "Cheapest in radius",
  "@approachPriceModeCheapestInRadius": {
    "description": "Choice chip — overlay shows the price at the cheapest station currently within the radius."
  },
  "approachMinPollLabel": "Min refresh",
  "@approachMinPollLabel": {
    "description": "Slider label for the minimum poll interval (seconds) used by the approach detector."
  },
  "approachMinPollCaption": "Floor on how often the overlay refreshes the nearest station (faster at speed, never tighter than {seconds} s)",
  "@approachMinPollCaption": {
    "description": "Caption under the min-poll slider.",
    "placeholders": {
      "seconds": {
        "type": "int",
        "example": "5"
      }
    }
  },
  "approachTestSimulateButton": "Test Fuel Station Radar",
  "@approachTestSimulateButton": {
    "description": "Button on the trip-recording screen that pushes a synthetic ApproachInRadius into the PiP for 30 s so the user can verify the price layout without driving (#2163)."
  },
  "approachTestStopButton": "Stop test",
  "@approachTestStopButton": {
    "description": "Button that aborts the in-app Fuel Station Radar simulation (#2163)."
  },
  "approachTestActiveCaption": "Test active — radar shows the price for {station}",
  "@approachTestActiveCaption": {
    "description": "Caption shown under the test button while a simulated approach is running (#2163).",
    "placeholders": {
      "station": {
        "type": "String",
        "example": "Pézenas Carburant"
      }
    }
  },
  "approachTestUnavailable": "Add a favorite station to test the Fuel Station Radar",
  "@approachTestUnavailable": {
    "description": "Caption shown when the test button is disabled because no favorite station is available as a target (#2163)."
  }
}
