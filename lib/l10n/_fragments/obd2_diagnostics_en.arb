  "@obd2DiagnosticsReconnectReasonLine": {
    "description": "One failed-reconnect-attempt reason-tally row on the OBD2 diagnostics card (#2905). reason is the low-cardinality failure tag (rfcomm-open-fail / gatt-133 / device-not-connected / timeout / other), count how many attempts failed for that reason this session.",
    "placeholders": {
      "reason": {
        "type": "String"
      },
      "count": {
        "type": "int"
      }
