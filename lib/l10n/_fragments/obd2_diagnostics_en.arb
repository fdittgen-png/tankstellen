{
  "obd2DiagnosticsTitle": "OBD2 communication health",
  "@obd2DiagnosticsTitle": {
    "description": "Title of the read-only OBD2 communication-health diagnostics card on the Trip detail screen + the dev-tools screen (#2470/#2471, Epic #2463). The OBD2 analogue of the GPS sampling diagnostics card. Only visible in Developer / Debug mode."
  },
  "obd2DiagnosticsHeader": "{percent}% complete · {duty}% duty · {drops, plural, =0{no drops} =1{1 drop} other{{drops} drops}}",
