{
  "unifiedFilterFuel": "Fuel",
  "@unifiedFilterFuel": {
    "description": "Filter chip label that narrows the unified search list to fuel pumps only (#1116 phase 3c)."
  },
  "unifiedFilterEv": "EV",
  "@unifiedFilterEv": {
    "description": "Filter chip label that narrows the unified search list to EV chargers only (#1116 phase 3c)."
  },
  "unifiedFilterBoth": "Both",
  "@unifiedFilterBoth": {
    "description": "Filter chip label that shows fuel pumps and EV chargers together in the unified search list (default selection, #1116 phase 3c)."
  },
  "unifiedNoResultsForFilter": "No results match this filter",
  "@unifiedNoResultsForFilter": {
    "description": "Empty-state placeholder shown in the unified search list when the active filter (Fuel / EV / Both) leaves zero options (#1116 phase 3c)."
  },
  "searchFailedSnackbar": "Search failed — please try again",
  "@searchFailedSnackbar": {
    "description": "Error snackbar shown when a search request fails. Replaces a raw exception toString() that previously leaked stack-like text to the user (#1692)."
  },
  "routeStationCount": "{count, plural, =1{1 station} other{{count} stations}}",
  "@routeStationCount": {
    "description": "Station count shown in the route-results summary line (e.g. '29 stations'). Pluralised so '1 station' reads naturally (#2622).",
    "placeholders": {
      "count": {
        "type": "int"
      }
    }
  },
  "stationUpdatedLabel": "Updated {time}",
  "@stationUpdatedLabel": {
    "description": "Wraps a station's pre-formatted last-updated timestamp so the value reads as a freshness indicator rather than a bare code (#2622). {time} is the upstream-provided, already-localized time string.",
    "placeholders": {
      "time": {
        "type": "String",
        "example": "10:30"
      }
    }
  },
  "amenityMoreTooltip": "Also: {names}",
  "@amenityMoreTooltip": {
    "description": "Tooltip / accessibility label on the '+N' amenity overflow pill, listing the hidden amenities by localized name (#2622). {names} is a comma-joined list.",
    "placeholders": {
      "names": {
        "type": "String",
        "example": "ATM, WiFi"
      }
    }
  },
  "favoriteAdd": "Add to favorites",
  "@favoriteAdd": {
    "description": "Tooltip / accessibility label on the station-card favourite star when the station is NOT yet a favourite (#2622)."
  },
  "favoriteRemove": "Remove from favorites",
  "@favoriteRemove": {
    "description": "Tooltip / accessibility label on the station-card favourite star when the station IS already a favourite (#2622)."
  },
  "loyaltyRawPriceTooltip": "Raw: {price}",
  "@loyaltyRawPriceTooltip": {
    "description": "Tooltip on the price headline when a loyalty discount applies, surfacing the un-discounted raw price for power users (#2622). {price} is an already-formatted price string.",
    "placeholders": {
      "price": {
        "type": "String",
        "example": "€1.85"
      }
    }
  },
  "routeDataSourceMulti": "{sources}",
  "@routeDataSourceMulti": {
    "description": "Multi-country data-source attribution shown above a cross-border route result, joining each crossed country's provider credit (#2622). {sources} is the pre-joined ' · '-separated list, e.g. 'France — Prix-Carburants · Spain — Geoportal Gasolineras'.",
    "placeholders": {
      "sources": {
        "type": "String",
        "example": "France — Prix-Carburants · Spain — Geoportal Gasolineras"
      }
    }
  },
  "stationUnbrandedTitle": "Unbranded station",
  "@stationUnbrandedTitle": {
    "description": "Station-card title fallback for a forecourt that carries no brand AND no station name (#2926). The street stays as the address subtitle; this label replaces showing the bare street as a duplicate title."
  },
  "unsupportedRegionTitle": "Not available in your region yet",
  "@unsupportedRegionTitle": {
    "description": "Title of the dismissible banner shown on the search screen when the user's GPS-detected country has no fuel-price provider (#3361). Explains the lack of nearby prices is a coverage gap, not a bug."
  },
  "unsupportedRegionBody": "We don't have fuel prices for your country yet, so results may be empty or from another country. You can still pick a supported country in the search settings.",
  "@unsupportedRegionBody": {
    "description": "Body of the unsupported-region banner (#3361). Tells the user fuel-price data isn't available for their detected country and that they can manually choose a supported country."
  },
  "unsupportedRegionDismiss": "Got it",
  "@unsupportedRegionDismiss": {
    "description": "Dismiss button on the unsupported-region banner (#3361)."
  },
  "configureCountryTitle": "Set your country",
  "@configureCountryTitle": {
    "description": "Title of the dismissible banner shown when the user's detected country IS supported but they haven't configured it (#3361), so the app is showing another country's prices."
  },
  "configureCountryBody": "Your country is supported, but it isn't set up yet — so prices may be from another country. Choose your country in the search settings to see local prices.",
  "@configureCountryBody": {
    "description": "Body of the configure-country banner (#3361). Tells the user their country is supported but unconfigured, and to set it in the search settings."
  }
}
