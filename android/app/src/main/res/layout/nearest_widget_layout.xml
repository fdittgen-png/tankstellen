<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background"
    android:id="@+id/nearest_widget_root">

    <!-- Header row: title + last update + refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nearest_widget_name"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary" />

        <TextView
            android:id="@+id/nearest_updated_at"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:paddingEnd="6dp"
            android:textColor="@color/widget_text_secondary" />

        <ImageView
            android:id="@+id/nearest_refresh"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_popup_sync"
            android:contentDescription="@string/widget_refresh"
            android:padding="2dp"
            android:tint="@color/widget_icon_tint" />
    </LinearLayout>

    <!-- Station list (up to 3 visible) -->
    <LinearLayout
        android:id="@+id/nearest_station_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/nearest_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nearest_widget_empty"
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:gravity="center"
        android:paddingTop="8dp"
        android:visibility="gone" />
</LinearLayout>
