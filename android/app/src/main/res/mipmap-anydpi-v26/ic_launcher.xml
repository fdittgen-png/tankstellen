<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+). The foreground is a vector drawable
  whose geometry already respects the 72dp safe zone; no inset wrapper
  needed. Pre-API-26 devices fall back to the legacy PNG in
  mipmap-<density>/ic_launcher.png (kept intentionally — see ASSET_SPEC
  "Legacy square icon" section).
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@color/ic_launcher_background"/>
  <foreground android:drawable="@drawable/ic_launcher_foreground"/>
</adaptive-icon>
