<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive launcher icon (API 26+). The `<background>` MUST point to a
  drawable, not a `@color/X` reference, because Samsung OneUI and
  several other third-party launchers silently ignore `@color/X` in
  the background slot and render only the foreground — which on a
  transparent foreground PNG makes the icon look like a white glyph
  on a checkered/transparent background instead of green.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@drawable/ic_launcher_background"/>
  <foreground>
      <inset
          android:drawable="@drawable/ic_launcher_foreground"
          android:inset="16%" />
  </foreground>
</adaptive-icon>
