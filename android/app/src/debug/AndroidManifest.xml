<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Android Auto v1 (#2948 / epic #2946) — DEBUG-ONLY enablement.
         The main manifest keeps the CarAppService <service>, the
         androidx.car.app meta-data and the FOREGROUND_SERVICE permissions
         GATED (commented out / tools:node="remove") so the publicly
         distributed Play + F-Droid builds stay shippable until Google's
         "Foreground Service Use" form (#1498) is approved by the maintainer.
         This debug overlay re-enables them ONLY for the debuggable build so
         the car app is reachable on the Desktop Head Unit and an internal
         test track WITHOUT touching the reviewed-track manifest.

         tools:node="replace" is required: the main manifest marks
         FOREGROUND_SERVICE* with tools:node="remove", which otherwise wins
         the merge regardless of source-set priority. "replace" from this
         higher-priority debug overlay reinstates the permission for debug.

         Production-enable step (maintainer, post-#1498): move the <service>
         + meta-data into the main manifest and drop the tools:node="remove"
         from the FOREGROUND_SERVICE* permissions there. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"
        tools:node="replace"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"
        tools:node="replace"/>

    <application>
        <service
            android:name=".TankstellenCarAppService"
            android:exported="true"
            android:permission="android.permission.FOREGROUND_SERVICE"
            tools:node="replace">
            <intent-filter>
                <action android:name="androidx.car.app.CarAppService" />
                <category android:name="androidx.car.app.category.POI" />
            </intent-filter>
        </service>

        <meta-data
            android:name="androidx.car.app.minCarApiLevel"
            android:value="1"
            tools:node="replace" />
    </application>
</manifest>
